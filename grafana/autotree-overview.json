{
  "annotations": {"list": []},
  "description": "AutoTree serve metrics. Every query uses metric names emitted by /metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Logical KV token references divided by physical KV tokens for the latest completed request.",
      "fieldConfig": {"defaults": {"min": 1, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "kv_reuse_ratio", "legendFormat": "KV reuse", "refId": "A"}],
      "title": "KV reuse ratio",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Winning-branch tokens divided by generated tokens for the latest completed request.",
      "fieldConfig": {"defaults": {"max": 1, "min": 0, "unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "useful_token_ratio", "legendFormat": "Useful tokens", "refId": "A"}],
      "title": "Useful-token ratio",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Branches currently started but not terminal. The Helm HPA uses this metric as its KV-pressure proxy.",
      "fieldConfig": {"defaults": {"min": 0, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "active_branches", "legendFormat": "{{pod}}", "refId": "A"}],
      "title": "Active branches",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Latest completed-request throughput across all generated branches.",
      "fieldConfig": {"defaults": {"min": 0, "unit": "ops"}, "overrides": []},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "tokens_per_second", "legendFormat": "tokens/s", "refId": "A"}],
      "title": "Tokens per second",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Branch lifecycle event rates by outcome.",
      "fieldConfig": {"defaults": {"min": 0, "unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
      "id": 5,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (event) (rate(branch_events_total[5m]))", "legendFormat": "{{event}}", "refId": "A"}],
      "title": "Branch events / second",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Time to first token percentiles from the ttft_seconds histogram.",
      "fieldConfig": {"defaults": {"min": 0, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 6},
      "id": 6,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(ttft_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(ttft_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"}
      ],
      "title": "TTFT",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "HTTP request rates split by normalized route and status.",
      "fieldConfig": {"defaults": {"min": 0, "unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 6},
      "id": 7,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (endpoint, status) (rate(requests_total[5m]))", "legendFormat": "{{endpoint}} {{status}}", "refId": "A"}],
      "title": "Request rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Tree-KV capacity rejections, including failures that occur after an SSE stream has started.",
      "fieldConfig": {"defaults": {"min": 0, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14},
      "id": 8,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(increase(capacity_rejections_total[5m]))", "legendFormat": "capacity 429s", "refId": "A"}],
      "title": "KV capacity rejections (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Requests rejected by per-tenant generated-token quotas.",
      "fieldConfig": {"defaults": {"min": 0, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 14},
      "id": 9,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(increase(quota_rejections_total[5m]))", "legendFormat": "quota 429s", "refId": "A"}],
      "title": "Quota rejections (5m)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["autotree", "serving"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "AutoTree Serve Overview",
  "uid": "autotree-serve",
  "version": 1,
  "weekStart": ""
}
