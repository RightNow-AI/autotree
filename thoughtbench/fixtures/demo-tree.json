{
  "model": "autotree-deterministic",
  "base_url": "http://127.0.0.1:8000",
  "mode": "tree",
  "task_set": {
    "name": "thoughtbench-contract-fixtures",
    "path": "tasks.jsonl",
    "provenance": {
      "kind": "fixture",
      "source": "Bundled synthetic ThoughtBench contract fixtures",
      "license": "Repository license",
      "notice": "FIXTURE TASKS ONLY - NOT A REAL BENCHMARK RESULT."
    }
  },
  "output_path": "demo-tree.results.json",
  "budgets": [{"name": "tiny-tree-12", "max_tokens": 4, "tree_budget_tokens": 12}],
  "k_samples": 1,
  "seeds": [11, 22, 33],
  "concurrency": 2,
  "timeout_seconds": 30,
  "temperature": 0.7,
  "top_p": 1.0,
  "stop": [],
  "tree": {"policy": "beam", "branches": 3, "scorer": "fixture-score"},
  "pricing": {"input_per_million_usd": 0.1, "output_per_million_usd": 0.2}
}
